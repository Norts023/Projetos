<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SkyTycoon" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">#FF0D0D1A</item>
    </style>
    <style name="Theme.SkyTycoon.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FF0D0D1A</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.SkyTycoon</item>
    </style>
</resources>
